{
  "version": 10,
  "include": [
    "cmake/preset/ninja.json"
  ],
  "configurePresets": [
    {
      "name": "memsan",
      "inherits": "ninja",
      "cacheVariables": {
        "TOOLCHAIN_INCLUDES": "toolchain/fetch-dependencies;toolchain/linux-clang;toolchain/linux-clang-san-mem",
        "sl3_USE_INTERNAL_SQLITE3": "ON"
      }
    },
    {
      "name": "memsan-int",
      "inherits": "ninja",
      "cacheVariables": {
        "TOOLCHAIN_INCLUDES": "toolchain/fetch-dependencies;toolchain/linux-clang;toolchain/linux-clang-san-mem",
        "sl3_USE_INTERNAL_SQLITE3": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "memsan",
      "configurePreset": "memsan",
      "configuration": "Debug"
    },
    {
      "name": "memsan-int",
      "configurePreset": "memsan-int",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "memsan",
      "inherits": "ninja",
      "configurePreset": "memsan"
    }
  ]
}
