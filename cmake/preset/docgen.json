{
  "version": 10,
  "include": [
    "base.json"
  ],
  "configurePresets": [
    {
      "name": "docgen",
      "inherits": "base",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchain/fech-dependencies.cmake",
      "cacheVariables": {
        "CMAKE_COMPILE_WARNING_AS_ERROR": "OFF",
        "CMAKE_BUILD_TYPE": "None",
        "sl3_USE_COMMON_COMPILER_WARNINGS": "OFF",
        "sl3_USE_INTERNAL_SQLITE3": "OFF",
        "PROJECT_ADDONS": "add-on/coverage-gcov"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "docgen",
      "configurePreset": "docgen"
    },
    {
      "name": "docgen-doc",
      "configurePreset": "docgen",
      "targets": "doc"
    },
    {
      "name": "docgen-coverage",
      "configurePreset": "docgen",
      "targets": "coverage"
    }
  ],
  "testPresets": [
    {
      "name": "docgen",
      "inherits": "base",
      "configurePreset": "docgen"
    }
  ],
  "workflowPresets": [
    {
      "name": "docgen",
      "steps": [
        {
          "type": "configure",
          "name": "docgen"
        },
        {
          "type": "build",
          "name": "docgen"
        },
        {
          "type": "test",
          "name": "docgen"
        },
        {
          "type": "build",
          "name": "docgen-doc"
        },
        {
          "type": "build",
          "name": "docgen-coverage"
        }
      ]
    }
  ]
}
